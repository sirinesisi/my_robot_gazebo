<?xml version="1.0"?>
<robot name="cerine_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- MATERIALS FOR VISUALS -->
  <material name="white"><color rgba="1 1 1 1"/></material>
  <material name="blue"><color rgba="0 0 1 1"/></material>
  <material name="black"><color rgba="0 0 0 1"/></material>

  <!-- BASE LINK (The Body) -->
  <link name="base_link">
    <visual>
      <geometry><box size="0.4 0.4 0.15"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry><box size="0.4 0.4 0.15"/></geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
    </inertial>
  </link>

  <!-- NECK -->
  <link name="neck">
    <visual>
      <geometry><cylinder radius="0.03" length="0.2"/></geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="neck_joint" type="fixed">
    <parent link="base_link"/>
    <child link="neck"/>
    <origin xyz="0.1 0 0.175"/>
  </joint>

  <!-- HEAD & EYES -->
  <link name="head">
    <visual>
      <geometry><box size="0.1 0.15 0.1"/></geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="head_joint" type="fixed">
    <parent link="neck"/>
    <child link="head"/>
    <origin xyz="0 0 0.1"/>
  </joint>

  <!-- LEFT WHEEL -->
  <link name="left_wheel">
    <visual>
      <geometry><cylinder radius="0.1" length="0.04"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.1" length="0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="-0.1 0.225 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- RIGHT WHEEL -->
  <link name="right_wheel">
    <visual>
      <geometry><cylinder radius="0.1" length="0.04"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.1" length="0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="-0.1 -0.225 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- CASTER WHEEL (For Balance) -->
  <link name="caster_wheel">
    <visual>
      <geometry><sphere radius="0.05"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><sphere radius="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="0.15 0 -0.05"/>
  </joint>

  <!-- GAZEBO PHYSICS & MOVEMENT PLUGIN -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.45</wheel_separation>
      <wheel_radius>0.1</wheel_radius>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>
  </gazebo>

</robot>
